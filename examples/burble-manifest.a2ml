# SPDX-License-Identifier: MPL-2.0
# Example Groove Manifest: Burble Voice Platform

@groove-manifest(version="0.1.0"):
  @system(id="burble", name="Burble Voice Platform", version="1.2.0")

  @offers:
    @capability(id="voice",         version="2.1.0", interface="VoiceTransport"):
      @field(name="sample-rate",    type="int",  default=48000, min=8000, max=96000)
      @field(name="channels",       type="int",  default=2, min=1, max=8)
      @field(name="codec",          type="enum", options=["opus", "pcm", "aac"], default="opus")
      @field(name="spatial",        type="bool", default=true)
    @end
    @capability(id="text",          version="1.0.0", interface="TextChannel"):
      @field(name="max-length",     type="int",  default=4096)
      @field(name="markdown",       type="bool", default=true)
    @end
    @capability(id="presence",      version="1.0.0", interface="PresenceTracker")
    @capability(id="spatial-audio", version="1.0.0", interface="SpatialAudio")
    @capability(id="tts",           version="1.0.0", interface="TextToSpeech")
    @capability(id="stt",           version="1.0.0", interface="SpeechToText")
  @end

  @consumes:
    @capability(id="integrity", version="1.0+", interface="IntegrityVerifier")
    @capability(id="storage",   version="1.0+", interface="OctadStore")
  @end

  @requires:
    @security(encryption="required", min-tls="1.3")
  @end

  @heartbeat(interval-ms=5000, timeout-ms=15000)

  @endpoints:
    @endpoint(path="/.well-known/groove",           method="GET",  purpose="manifest")
    @endpoint(path="/.well-known/groove/connect",    method="POST", purpose="connect")
    @endpoint(path="/.well-known/groove/disconnect", method="POST", purpose="disconnect")
    @endpoint(path="/.well-known/groove/heartbeat",  method="GET",  purpose="heartbeat")
    @endpoint(path="/.well-known/groove/mesh",       method="GET",  purpose="topology")
  @end
@end
